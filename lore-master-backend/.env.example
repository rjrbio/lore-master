# =============================================================================
# Lore Master Backend — Variables de entorno
# =============================================================================
# Copia este archivo a .env y completa los valores

# --- Obligatorias ---
OPENAI_API_KEY=sk-...
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/loremaster?retryWrites=true&w=majority

# --- Servidor ---
NODE_ENV=production
PORT=3000
FRONTEND_URL=https://tu-dominio.com

# --- Docker Compose (puertos del host) ---
# BACKEND_PORT=3000
# FRONTEND_PORT=8080

# --- OpenAI (modelos) ---
OPENAI_CHAT_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- Chunking y búsqueda ---
MIN_CHUNK_LENGTH=120
MAX_CHUNK_LENGTH=1900
VECTOR_SEARCH_THRESHOLD=0.72
